    </svg>
    <span class="sr-only">Instagram</span>
  </a>
  {%- endif %}

  {%- if venue.tiktok_url %}
  <a href="{{ venue.tiktok_url }}"
     target="_blank" rel="noopener noreferrer"
     class="venue-link venue-link--tiktok"
     title="TikTok" aria-label="{{ venue.name }} on TikTok">
    <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.27 6.27 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V8.67a8.18 8.18 0 0 0 4.78 1.52V6.73a4.85 4.85 0 0 1-1.01-.04z"/>
    </svg>
    <span class="sr-only">TikTok</span>
  </a>
  {%- endif %}

  {%- if venue.website_url %}
  <a href="{{ venue.website_url }}"
     target="_blank" rel="noopener noreferrer"
     class="venue-link venue-link--website"
     title="Website" aria-label="{{ venue.name }} website">
    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <circle cx="12" cy="12" r="10"/>
      <line x1="2" y1="12" x2="22" y2="12"/>
      <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
    </svg>
    <span class="sr-only">Website</span>
  </a>
  {%- endif %}

</div>
{%- endif %}
{% endmacro %}
